@startuml class_diagram

skinparam backgroundColor white
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 11
skinparam classAttributeIconSize 0
skinparam linetype ortho

skinparam class {
  ArrowColor #555555
  BorderColor #555555
}

' ══════════════════════════════════════════════════
'  LAYER 1 — Data Structures
' ══════════════════════════════════════════════════
package "Layer 1 — Data Structures" #FFF2CC {

  class MySinglyLinkedList<T> #FFD700 {
    - head: Node<T>
    - size: int
    + insertAtHead(data: T): void
    + insertAtTail(data: T): void
    + remove(data: T): boolean
    + find(data: T): T
    + contains(data: T): boolean
    + toArray(): Object[]
    + size(): int
    + isEmpty(): boolean
    + removeHead(): T
  }

  class MyQueue<T> #FFD700 {
    - list: MySinglyLinkedList<T>
    + enqueue(data: T): void
    + dequeue(): T
    + peek(): T
    + isEmpty(): boolean
    + size(): int
  }

  class "MyBST<K extends Comparable<K>, V>" as MyBST #FFD700 {
    - root: Node<K,V>
    - size: int
    + put(key: K, value: V): void
    + get(key: K): V
    + delete(key: K): void
    + contains(key: K): boolean
    + inOrderKeys(): MySinglyLinkedList<K>
    + inOrderValues(): MySinglyLinkedList<V>
  }

  class "MyMaxHeap<T extends Comparable<T>>" as MyMaxHeap #FFD700 {
    - heap: T[]
    - size: int
    + insert(item: T): void
    + extractMax(): T
    + topK(k: int): MySinglyLinkedList<T>
  }

  class "MyMinHeap<T extends Comparable<T>>" as MyMinHeap #FFD700 {
    - heap: T[]
    - capacity: int
    + insert(item: T): void
    + extractMin(): T
    + offerIfBetter(item: T): void
    + toSortedArray(): Object[]
  }

  class MyGraph #FFD700 {
    - adjList: MyBST<String, MySinglyLinkedList<String>>
    - numVertices: int
    - numEdges: int
    + addVertex(userId: String): void
    + addEdge(u1: String, u2: String): void
    + removeEdge(u1: String, u2: String): void
    + getNeighbors(userId: String): MySinglyLinkedList<String>
    + bfsLevel2(userId: String): String[]
    + hasVertex(userId: String): boolean
    + hasEdge(u1: String, u2: String): boolean
  }

  class MyAdjacencyMatrix #FFD700 {
    - matrix: boolean[][]
    - vertices: String[]
    - idToIndex: MyBST<String, Integer>
    + addVertex(userId: String): void
    + addEdge(u1: String, u2: String): void
    + bfsLevel2(userId: String): String[]
    + getMemoryBytes(): long
  }

  class MyDFS #FFD700 {
    {static} + dfsLevel2(graph: MyGraph, userId: String): String[]
    {static} + dfsLevel2(graph: MyAdjacencyMatrix, userId: String): String[]
  }
}

' ══════════════════════════════════════════════════
'  LAYER 2 — Models
' ══════════════════════════════════════════════════
package "Layer 2 — Models" #E2EFDA {

  class User #A9D08E {
    - id: String
    - name: String
    - username: String
    - bio: String
    - joinedDate: String
    + toJSONObject(): JSONObject
    {static} + fromJSONObject(json: JSONObject): User
  }

  class Recommendation #A9D08E {
    - user: User
    - mutualFriends: int
    - jaccardSimilarity: double
    + compareTo(other: Recommendation): int
    + toJSONObject(): JSONObject
  }

  Recommendation ..|> "Comparable<Recommendation>" : implements
}

' ══════════════════════════════════════════════════
'  LAYER 3 — Services
' ══════════════════════════════════════════════════
package "Layer 3 — Services" #DDEBF7 {

  class DataStore #8FAADC {
    - directoryPath: String
    + load(graph, userBst): void
    + save(graph, userBst): void
    + seedIfEmpty(graph, userBst): void
  }

  class GraphService #8FAADC {
    - graph: Graph
    - userBst: BinarySearchTree<String, User>
    - recommendationEngine: RecommendationEngine
    + addUser(name, username, bio): User
    + deleteUser(userId): boolean
    + addFriendship(u1, u2): boolean
    + removeFriendship(u1, u2): boolean
    + getAllUsers(): SinglyLinkedList<User>
    + getRecommendations(userId, k): SinglyLinkedList<Recommendation>
  }

  class RecommendationEngine #8FAADC {
    + getMutualFriendsCount(graph, u1, u2): int
    + getJaccardSimilarity(graph, u1, u2): double
    + getRecommendationsMaxHeap(graph, userBst, userId, k): SinglyLinkedList<Recommendation>
    + getRecommendationsMinHeap(graph, userBst, userId, k): SinglyLinkedList<Recommendation>
  }

  class SuggestionService #8FAADC {
    + computeJaccard(graph, u1, u2): double
    + getSuggestions(graph, userBst, userId, k): MySinglyLinkedList<Recommendation>
    {static} + runSelfTest(): void
  }

  class PerformanceTester #8FAADC {
    {static} + runBenchmarks(outputPath: String): void
  }
}

' ══════════════════════════════════════════════════
'  LAYER 4 — API
' ══════════════════════════════════════════════════
package "Layer 4 — API" #F2E6FF {

  class AppServer #D9B3FF {
    - server: HttpServer
    - graphService: GraphService
    + start(): void
    + stop(): void
    {static} + sendJsonResponse(ex, status, json): void
    {static} + handleOptions(ex): boolean
  }

  class UserHandler #D9B3FF {
    - graphService: GraphService
    + handle(ex: HttpExchange): void
  }

  class FriendHandler #D9B3FF {
    - graphService: GraphService
    + handle(ex: HttpExchange): void
  }

  class SuggestionHandler #D9B3FF {
    - graphService: GraphService
    + handle(ex: HttpExchange): void
  }

  class NetworkHandler #D9B3FF {
    - graphService: GraphService
    + handle(ex: HttpExchange): void
  }

  class BenchmarkHandler #D9B3FF {
    + handle(ex: HttpExchange): void
  }

  UserHandler ..|> HttpHandler : implements
  FriendHandler ..|> HttpHandler : implements
  SuggestionHandler ..|> HttpHandler : implements
  NetworkHandler ..|> HttpHandler : implements
  BenchmarkHandler ..|> HttpHandler : implements
}

' ══════════════════════════════════════════════════
'  RELATIONSHIPS
' ══════════════════════════════════════════════════

' Layer 1 internal
MyQueue --> MySinglyLinkedList : uses
MyGraph --> MyBST : uses
MyGraph --> MySinglyLinkedList : uses
MyGraph --> MyQueue : uses
MyDFS --> MyGraph : uses
MyDFS --> MyAdjacencyMatrix : uses
MyAdjacencyMatrix --> MyBST : uses
MyAdjacencyMatrix --> MyQueue : uses

' Layer 2 internal
Recommendation --> User : contains

' Layer 3 → Layer 1
SuggestionService --> MyGraph : uses
SuggestionService --> MyMinHeap : uses
RecommendationEngine --> MyGraph : uses
RecommendationEngine --> MyMaxHeap : uses
RecommendationEngine --> MyMinHeap : uses

' Layer 3 internal
GraphService --> DataStore : uses
GraphService --> RecommendationEngine : uses
PerformanceTester --> RecommendationEngine : uses

' Layer 4 → Layer 3
AppServer --> UserHandler : registers
AppServer --> FriendHandler : registers
AppServer --> SuggestionHandler : registers
AppServer --> NetworkHandler : registers
AppServer --> BenchmarkHandler : registers
UserHandler --> GraphService : uses
FriendHandler --> GraphService : uses
SuggestionHandler --> GraphService : uses
NetworkHandler --> GraphService : uses

@enduml
